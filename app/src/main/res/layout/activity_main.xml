<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#141218">

    <!-- AppBar & Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#141218"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="AnomX"
            app:titleTextColor="#E6E0E9" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:text="Emergency Response System"
                android:textColor="#CAC4D0"
                android:textSize="14sp" />

            <!-- Emergency Action Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/material_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Manual Trigger"
                    android:textColor="#E6E0E9"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/manualSendBtn"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:text="EMERGENCY SOS"
                    android:textColor="#381E72"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#FFB4AB" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSirenOverdrive"
                    android:layout_width="250dp"
                    android:layout_height="60dp"
                    android:layout_marginTop="24dp"
                    android:text="🚨 SIREN OVERDRIVE 🚨"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:backgroundTint="#B30000"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Service Controls Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/material_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="Shake to Alert"
                    android:textColor="#E6E0E9"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/serviceStatusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Status: Loading..."
                    android:textColor="#CAC4D0"
                    android:textSize="14sp"
                    android:textStyle="italic" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/startServiceBtn"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#D0BCFF"
                        android:text="ON"
                        android:textColor="#381E72"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stopServiceBtn"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#4A4458"
                        android:text="OFF"
                        android:textColor="#E8DEF8"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Location Map Layout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/material_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Live Location"
                    android:textColor="#E6E0E9"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Real Interactive Map Layout -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="#141218"
                    app:cardCornerRadius="16dp">

                    <WebView
                        android:id="@+id/mapWebView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/currentCoordinatesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Locating GPS..."
                    android:textColor="#CAC4D0"
                    android:textSize="14sp"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- Contacts Card -->
            
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/modeToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@+id/btnModeSms">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeSms"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SMS Mode"
                    android:textColor="#E6E0E9"
                    app:strokeColor="#4A4458" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeWhatsApp"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="WhatsApp"
                    android:textColor="#E6E0E9"
                    app:strokeColor="#4A4458" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                android:id="@+id/contactsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:background="@drawable/material_surface"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Emergency Contacts"
                    android:textColor="#E6E0E9"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/phoneInput"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Phone Number"
                        android:inputType="phone"
                        android:textColor="#E6E0E9"
                        android:textColorHint="#938F99" />

                    <ImageButton
                        android:id="@+id/addButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:background="@android:color/transparent"
                        android:src="@android:drawable/ic_input_add"
                        app:tint="#D0BCFF" />
                </LinearLayout>

                <ListView
                    android:id="@+id/listView"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp"
                    android:divider="#4A4458"
                    android:dividerHeight="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMoreDetails"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="View National Directory"
                    android:textColor="#E6E0E9"
                    app:strokeColor="#D0BCFF" />

            </LinearLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom|center_horizontal">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="~ Eurt-labs"
                    android:textColor="#938F99"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>