<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/material_surface"
    android:orientation="vertical"
    android:paddingTop="24dp"
    android:paddingBottom="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="Emergency Services"
        android:textColor="#E6E0E9"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="350dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- National Emergency -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDial112"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="National Emergency - 112"
                android:textColor="#FFB4AB"
                app:strokeColor="#FFB4AB" />

            <!-- Police -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDial100"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Police Control Room - 100"
                android:textColor="#D0BCFF"
                app:strokeColor="#4A4458" />

            <!-- Ambulance -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDial108"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Ambulance Service - 108"
                android:textColor="#D0BCFF"
                app:strokeColor="#4A4458" />

            <!-- Fire -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDial101"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Fire Brigade - 101"
                android:textColor="#D0BCFF"
                app:strokeColor="#4A4458" />

            <!-- Women Helpline -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDial1091"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Women Helpline - 1091"
                android:textColor="#D0BCFF"
                app:strokeColor="#4A4458" />

            <!-- Highway Rescue -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDial1033"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Highway Rescue - 1033"
                android:textColor="#D0BCFF"
                app:strokeColor="#4A4458" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
